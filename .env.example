# Postgres
POSTGRES_USER=hotel
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hotel

# Backend uses the `db` service name as the host (compose network DNS)
DATABASE_URL=postgres://hotel:changeme@db:5432/hotel

# Session signing secret - generate a long random value for real use,
# e.g. `openssl rand -hex 64`
SESSION_SECRET=dev-only-please-change-this-to-a-long-random-secret-0123456789

# Seeded accounts (created once by the `seed` service; safe to re-run)
ADMIN_EMAIL=owner@hotel.test
ADMIN_PASSWORD=changeme-admin
EMPLOYEE_EMAIL=staff@hotel.test
EMPLOYEE_PASSWORD=changeme-staff
